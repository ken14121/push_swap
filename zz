int	main(int argc, char **argv)
{
	t_stack	stack_a;
	t_stack	stack_b;
	int		i;

	stack_a.head = NULL;
	stack_a.tail = NULL;
	stack_a.size = 0;

	stack_b.head = NULL;
	stack_b.tail = NULL;
	stack_b.size = 0;

	if (argc < 2)
		return (0);

	check_errors(argc, argv);

	i = 1;
	while (i < argc)
	{
		add_back(&stack_a, ft_atoi(argv[i]));
