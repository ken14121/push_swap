#include "push_swap.h"

size_t	ft_strlen(const char *s)
{
	size_t	i;

	i = 0;
	while (s[i] != '\0')
		i++;
	return (i);
}

static char	**ft_free_all(char **split, size_t count)
{
	while (count > 0)
		free(split[--count]);
	free(split);
	return (NULL);
}

static char	*ft_copy_word(const char *s, int start, size_t len)
{
	char	*word;
	size_t	i;

	word = (char *)malloc(len + 1);
	if (!word)
		return (NULL);
	i = 0;
	while (i < len)
	{
		word[i] = s[start + i];
		i++;
	}
	word[i] = '\0';
	return (word);
}

static char	**ft_split_check(const char *s, char c, char **split)
{
	size_t	i;
	size_t	j;
	int		start;

	i = 0;
	j = 0;
	start = -1;
	while (i <= ft_strlen(s))
	{
		if (s[i] != c && start == -1)
			start = i;
		else if ((s[i] == c || s[i] == '\0') && start != -1)
		{
			split[j] = ft_copy_word(s, start, i - start);
			if (!split[j])
			{
				return (ft_free_all(split, j));
			}
			j++;
			start = -1;
		}
		i++;
	}
	split[j] = NULL;
	return (split);
}

static int	ft_count_words(const char *s, char c)
{
	int	count;
	int	trigger;
	int	i;

	count = 0;
	trigger = 0;
	i = 0;
	while (s[i] != '\0')
	{
		if (s[i] != c && trigger == 0)
		{
			trigger = 1;
			count++;
		}
		else if (s[i] == c)
			trigger = 0;
		i++;
	}
	return (count);
}

char	**ft_split(char const *s, char c)
{
	char	**split;
	int		count;

	if (!s)
		return (NULL);
	count = ft_count_words(s, c);
	split = malloc((count + 1) * sizeof(char *));
	if (!split)
		return (NULL);
	split = ft_split_check(s, c, split);
	return (split);
}


