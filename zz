// 数字・符号チェック
static int	is_all_digit(char *str)
{
	int	i;

	i = 0;
	if (str[i] == '-' || str[i] == '+')
		i++;
	if (!str[i])
		return (0);
	while (str[i])
	{
		if (str[i] < '0' || str[i] > '9')
			return (0);
		i++;
	}
	return (1);
}

// splitしたメモリを掃除する
void	free_matrix(char **matrix)
{
	int	i;

	i = 0;
	if (!matrix)
		return ;
	while (matrix[i])
		free(matrix[i++]);
	free(matrix);
}

void	parse_args(int argc, char **argv, t_stack *stack_a)
{
	int		i;
	int		j;
	char	**temp;
	long	val;

	i = 1;
	while (i < argc)
	{
		temp = ft_split(argv[i], ' ');
		if (!temp)
			error_exit();
		j = 0;
		while (temp[j])
		{
			if (!is_all_digit(temp[j]))
			{
				free_matrix(temp);
				error_exit();
			}
			val = ft_atol(temp[j]);
			if (val < INT_MIN || val > INT_MAX)
			{
				free_matrix(temp);
				error_exit();
			}
			add_back(stack_a, (int)val);
			j++;
		}
		free_matrix(temp);
		i++;
	}
}

