#include "push_swap.h"

void	free_matrix(char **matrix)
{
	int	i;

	i = 0;
	if (!matrix)
		return ;
	while (matrix[i])
	{
		free(matrix[i]);
		i++;
	}
	free(matrix);
}

static int	is_all_digit(char *str)
{
	int	i = 0;

	if (str[i] == '-' || str[i] == '+')
		i++;
	if (!str[i])
		return (0);
	while (str[i])
	{
		if (str[i] < '0' || str[i] > '9')
			return (0);
		i++;
	}
	return (1);
}

void	check_errors(int argc, char **argv)
{
	int		i;
	int		j;
	long	tmp;
	char	**temp;

	i = 1;
	while (i < argc)
	{
		temp = ft_split(argv[i], ' ');
		if (!temp)
			error_exit();

		j = 0;
		while (temp[j])
		{
			if (!is_all_digit(temp[j]))
			{
				free_matrix(temp);
				error_exit();
			}
			tmp = ft_atol(temp[j]);
			if (tmp < -2147483648 || tmp > 2147483647)
			{
				free_matrix(temp);
				error_exit();
			}
			j++;
		}
		free_matrix(temp);
		i++;
	}
}

